{
  "name": "pricelens-nigeria",
  "version": "1.0.0",
  "private": true,
  "description": "PriceLens Nigeria — Smart Retail Price Intelligence Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run start:dev",
    "dev:ai": "cd apps/ai && uvicorn main:app --reload --port 8000",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:ai\"",
    "build": "turbo run build",
    "build:web": "cd apps/web && npm run build",
    "build:api": "cd apps/api && npm run build",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:migrate": "cd packages/database && npx prisma migrate dev",
    "db:migrate:prod": "cd packages/database && npx prisma migrate deploy",
    "db:seed": "cd packages/database && npx ts-node --esm seed.ts",
    "db:studio": "cd packages/database && npx prisma studio",
    "db:reset": "cd packages/database && npx prisma migrate reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
