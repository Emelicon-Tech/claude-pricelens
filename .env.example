# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pricelens:pricelens_secret@localhost:5432/pricelens_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=pricelens_super_secret_jwt_key_change_in_production_2026
JWT_REFRESH_SECRET=pricelens_refresh_secret_key_change_in_production_2026
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── AWS S3 ─────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=pricelens-uploads

# ── Payments ───────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_key

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Phone OTP (Termii) ────────────────────────────────────────────────────────
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=PriceLens

# ── Email ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@pricelens.com.ng

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=pricelens_nextauth_secret_change_in_production
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_key
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
AI_PORT=8000
